# PostgreSQL connection string used by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://user:password@localhost:5432/dms_db?schema=public"

# Public production URL used for canonical and Open Graph metadata
NEXT_PUBLIC_APP_URL="https://dmsmanagers.tominho.com/"

# Secret key for signing JWT authentication cookies
JWT_SECRET="replace-with-strong-secret"

# Optional job runner configuration. Jobs stay disabled unless explicitly enabled.
# DMS_JOB_RUNNER accepts: disabled | railway-cron | http-cron | manual
DMS_JOB_RUNNER="disabled"

# Secret for internal job endpoints or cron invocations. In production use 32+ characters.
# Vercel Cron can also provide CRON_SECRET; DMS_JOB_SECRET takes precedence when present.
DMS_JOB_SECRET="replace-with-strong-job-secret"
# CRON_SECRET="replace-with-provider-cron-secret"

# Migration feature flags. Accepted true values: true, 1, on, yes, enabled.
DMS_FEATURE_COLLECTIVE_SALES="false"
DMS_FEATURE_GAMIFICATION="false"
DMS_FEATURE_NOTICES="false"
DMS_FEATURE_REPORTS="false"

# Trust proxy-provided client IP headers for login rate-limit buckets only when
# the ingress/proxy overwrites these headers and clients cannot spoof them.
DMS_TRUST_PROXY_HEADERS="false"

# Allow the destructive UAT seed to run against disposable remote preview DBs.
# Leave false for local work unless the target is explicitly non-production.
DMS_ALLOW_REMOTE_UAT_SEED="false"

# Optional: legacy MongoDB variables (only needed until all endpoints are migrated)
# MONGODB_URI="mongodb://user:password@localhost:27017/DMS"
# MONGODB_DB="DMS"

# Standard Node environment flag (development | production)
# NODE_ENV="development"
